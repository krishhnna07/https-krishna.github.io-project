function addPart() {
  const name = document.getElementById('pm-name').value.trim();
  const no   = document.getElementById('pm-no').value.trim();
  const qty  = parseInt(document.getElementById('pm-qty').value);
  const tol  = parseInt(document.getElementById('pm-tol').value) || 0;
  const hsn  = document.getElementById('pm-hsn').value.trim() || '3926';
  const gst  = parseInt(document.getElementById('pm-gst').value);
  const hasVariants = document.getElementById('pm-variants').value === 'yes';
  const low  = parseInt(document.getElementById('pm-low').value) || 50;

  if (!name || !no || !qty) { alert('Please fill Part Name, Part No. and Std Qty.'); return; }
  if (parts.find(p=>p.no===no)) { alert('Part No. already exists.'); return; }

  parts.push({ name, no, stdQty:qty, tol, hsn, gst, variants:hasVariants, lowAlert:low });

  // Init FG bins for new part
  if (hasVariants) { ['RH','LH'].forEach(v => { fgStock[`${name}|${v}`] = 0; }); }
  else { fgStock[`${name}|General`] = 0; }

  ['pm-name','pm-no','pm-qty','pm-hsn','pm-low'].forEach(id => document.getElementById(id).value='');
  document.getElementById('pm-tol').value = '0';
  renderPartsTable();
  populatePartSelects();
  addActivity('parts', `New part added: ${name} (${no})`, `Std qty: ${qty}, Variants: ${hasVariants?'RH+LH':'None'}`, 'info');
}

function renderPartsTable() {
  const tbody = document.getElementById('parts-table-body');
  if (!parts.length) { tbody.innerHTML='<tr><td colspan="9"><div class="empty-state">No parts added yet</div></td></tr>'; return; }
  tbody.innerHTML = parts.map((p,i) => `
    <tr>
      <td><strong>${p.name}</strong></td>
      <td><span class="mono">${p.no}</span></td>
      <td><strong>${p.stdQty}</strong> NOS</td>
      <td>± ${p.tol}</td>
      <td>${p.variants ? '<span class="tag rh">RH</span> <span class="tag lh">LH</span>' : '<span class="tag gen">General</span>'}</td>
      <td>${p.hsn}</td>
      <td>${p.gst}%</td>
      <td>${p.lowAlert}</td>
      <td><button class="del-btn" onclick="deletePart(${i})">🗑</button></td>
    </tr>`).join('');
}

function deletePart(i) {
  if (!confirm(`Remove "${parts[i].name}"? This will also remove its FG bins.`)) return;
  const name = parts[i].name;
  parts.splice(i,1);
  Object.keys(fgStock).filter(k=>k.startsWith(name+'|')).forEach(k=>delete fgStock[k]);
  renderPartsTable();
  populatePartSelects();
}

