  pdItems[i][field] = field === 'qty' || field === 'rate' || field === 'gst' ? parseFloat(val)||0 : val;
  if (field === 'partName') {
    const p = parts.find(x=>x.name===val);
    if (p) {
      pdItems[i].gst = p.gst;
      pdItems[i].variant = p.variants ? 'RH' : 'General';
    }
  }
  renderPDItems();
}

function removePDItem(i) {
  pdItems.splice(i, 1);
  renderPDItems();
}

function generatePDI() {
  const customer   = document.getElementById('pd-customer').value.trim();
  const po         = document.getElementById('pd-po').value.trim();
  const dateVal    = document.getElementById('pd-date').value;
  const gstin      = document.getElementById('pd-gstin').value.trim();
  const address    = document.getElementById('pd-address').value.trim();
  const payment    = document.getElementById('pd-payment').value;
  const remarks    = document.getElementById('pd-remarks').value.trim();
  const preparedBy = document.getElementById('pd-preparedby').value.trim();

  if (!customer) { showAlert('pd-alert','warn','⚠ Missing','Please enter customer name.'); return; }
  if (!pdItems.length || pdItems.every(i=>!i.partName||!i.qty)) {
    showAlert('pd-alert','warn','⚠ No Items','Add at least one part line with quantity.'); return;
  }

  const validItems = pdItems.filter(i=>i.partName && i.qty > 0);
  if (!validItems.length) { showAlert('pd-alert','warn','⚠ Incomplete','Fill in part name and quantity for each line.'); return; }

  const today    = new Date().toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'});
  const dispDate = dateVal ? new Date(dateVal).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) : 'TBD';
  const pdiNo    = `UPC/PDI/25-26/${pdiCounter++}`;

  // Calculate totals
  let grandSubtotal = 0, grandGST = 0;
  validItems.forEach(item => {
    grandSubtotal += item.qty * item.rate;
    grandGST      += item.qty * item.rate * item.gst / 100;
  });
  const grandTotal = grandSubtotal + grandGST;
  const totalQty   = validItems.reduce((a,i)=>a+i.qty,0);

  // Stock availability check
  const stockWarnings = validItems.filter(item => {
    const avail = fgStock[`${item.partName}|${item.variant}`] || 0;
    return avail < item.qty;
  });

  // Save to log
  const pdiEntry = {
    pdiNo, date: today, customer, po: po||'—', items: validItems,
    totalQty, grandSubtotal, grandGST, grandTotal,
    dispDate, gstin, address, payment, remarks, preparedBy: preparedBy||'—',
    status: 'Pending'
  };
  pdiLog.unshift(pdiEntry);
  pdiStats.total++;
  pdiStats.pending++;
  updatePDIStats();
  renderPDILog();
  updateNavBadges();
  addActivity('pre-disp', `PDI ${pdiNo} — ${customer}`, `${validItems.length} part(s), Total: ₹${grandTotal.toFixed(2)}`, 'info');

  // Show stock warning if any
  if (stockWarnings.length) {
    showAlert('pd-alert','warn',`⚠ Stock Shortfall for ${stockWarnings.length} item(s)`,
      stockWarnings.map(i=>`${i.partName} (${i.variant}): Required ${i.qty}, Available ${fgStock[i.partName+'|'+i.variant]||0}`).join(' | '));
  } else {
    showAlert('pd-alert','ok','✔ Stock Available','All items have sufficient FG stock for this dispatch.');
  }

  // Render preview
  const itemRows = validItems.map((item,idx) => {
    const p = parts.find(x=>x.name===item.partName);
    const subtotal = item.qty * item.rate;
    const gstAmt   = subtotal * item.gst / 100;
    return `<tr>
      <td>${idx+1}</td>
      <td><strong>${p?p.no:'—'}</strong></td>
      <td>${item.partName} ${item.variant!=='General'?'('+item.variant+')':''}</td>
      <td>${p?p.hsn:'3926'}</td>
      <td>${item.qty}</td>
      <td>NOS</td>
      <td>₹${parseFloat(item.rate).toFixed(2)}</td>
      <td>₹${subtotal.toFixed(2)}</td>
      <td>${item.gst}%</td>
      <td>₹${gstAmt.toFixed(2)}</td>
      <td><strong>₹${(subtotal+gstAmt).toFixed(2)}</strong></td>
    </tr>`;
  }).join('');

  document.getElementById('pd-preview-wrap').innerHTML = `
  <div class="doc-wrap" style="margin-top:18px" id="printable-doc">
    <!-- Watermark -->
    <div style="text-align:center;margin-bottom:4px">
      <span style="background:#fef3c7;color:#92400e;border:1.5px solid #fbbf24;border-radius:20px;
        padding:4px 18px;font-size:11px;font-weight:800;letter-spacing:1px">
        PRE-DISPATCH INVOICE — NOT A TAX INVOICE
      </span>
    </div>
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-top:12px">
      <div>
        <div class="doc-co">UNITECH PLASTO COMPONENTS PVT LTD</div>
        <div class="doc-co-sub">Ground Floor, Building No. 258/1, Pawar Wasti, Talegaon Chakan Road, Kharabwadi</div>
        <div class="doc-co-sub">Khed, Chakan – 410501, Maharashtra, Pune &nbsp;|&nbsp; GSTIN: 27AAACU6211E1ZP &nbsp;|&nbsp; PAN: AAACU6211E</div>
      </div>
      <div style="background:#0e7490;color:#fff;padding:8px 20px;border-radius:7px;font-weight:800;font-size:13px;letter-spacing:1px;text-align:right">
        PRE-DISPATCH<br>INVOICE
      </div>
    </div>
    <hr class="doc-divider" style="border-top-color:#0e7490">

    <div class="doc-meta" style="grid-template-columns:repeat(4,1fr)">
      <div class="doc-meta-box">
        <div class="doc-meta-lbl">PDI Number</div>
        <div class="doc-meta-val">${pdiNo}</div>
      </div>
      <div class="doc-meta-box">
        <div class="doc-meta-lbl">Created On</div>
        <div class="doc-meta-val">${today}</div>
      </div>
      <div class="doc-meta-box">
        <div class="doc-meta-lbl">Expected Dispatch</div>
        <div class="doc-meta-val">${dispDate}</div>
      </div>
      <div class="doc-meta-box">
        <div class="doc-meta-lbl">Customer PO No.</div>
        <div class="doc-meta-val">${po||'—'}</div>
      </div>
    </div>

    <div class="doc-meta" style="grid-template-columns:1fr 1fr;margin-top:0">
      <div class="doc-meta-box">
        <div class="doc-meta-lbl">Bill To / Dispatch To</div>
        <div class="doc-meta-val">${customer}</div>
        <div class="doc-meta-sub">${address||'—'}</div>
        ${gstin ? `<div class="doc-meta-sub">GSTIN: ${gstin}</div>` : ''}
      </div>
      <div class="doc-meta-box">
        <div class="doc-meta-lbl">Payment Terms</div>
        <div class="doc-meta-val">${payment}</div>
        <div class="doc-meta-sub">Prepared by: ${preparedBy||'—'}</div>
        ${remarks ? `<div class="doc-meta-sub" style="margin-top:4px;color:var(--amber)">📌 ${remarks}</div>` : ''}
      </div>
    </div>

    <table class="inv" style="margin-top:16px">
      <thead>
        <tr>
          <th>Sr.</th><th>Part No.</th><th>Description</th><th>HSN</th>
          <th>Qty</th><th>Unit</th><th>Rate ₹</th><th>Taxable ₹</th>
          <th>GST%</th><th>GST Amt ₹</th><th>Total ₹</th>
        </tr>
      </thead>
      <tbody>${itemRows}</tbody>
    </table>

    <div class="inv-totals">
      <table>
        <tr><td>Subtotal (Taxable)</td><td>₹${grandSubtotal.toFixed(2)}</td></tr>
        <tr><td>Total GST</td><td>₹${grandGST.toFixed(2)}</td></tr>
        <tr class="inv-total-row"><td>GRAND TOTAL</td><td>₹${grandTotal.toFixed(2)}</td></tr>
      </table>
    </div>

    <div class="doc-words"><strong>Amount in Words:</strong> ${numToWords(Math.round(grandTotal))} Only</div>

    <!-- Stock status table -->
    <div style="margin-top:16px;padding:12px 16px;background:${stockWarnings.length?'#fef9c3':'#f0fdf4'};border-radius:8px;border:1px solid ${stockWarnings.length?'#fbbf24':'#86efac'}">
      <div style="font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:0.6px;color:${stockWarnings.length?'#92400e':'var(--green)'};margin-bottom:8px">
        ${stockWarnings.length ? '⚠ Stock Availability Check — Shortfall Detected' : '✔ Stock Availability Check — All OK'}
      </div>
      <table style="width:100%;font-size:12px;border-collapse:collapse">
        <thead><tr style="background:rgba(0,0,0,0.05)">
          <th style="padding:5px 8px;text-align:left">Part</th>
          <th style="padding:5px 8px;text-align:left">Variant</th>
          <th style="padding:5px 8px;text-align:left">Required</th>
          <th style="padding:5px 8px;text-align:left">FG Stock</th>
          <th style="padding:5px 8px;text-align:left">Status</th>
        </tr></thead>
