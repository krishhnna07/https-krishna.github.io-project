function recordProduction() {
  const machine  = document.getElementById('prod-machine').value;
  const partName = document.getElementById('prod-part').value;
  const variant  = document.getElementById('prod-variant').value;
  const good     = parseInt(document.getElementById('prod-qty-good').value) || 0;
  const bad      = parseInt(document.getElementById('prod-qty-bad').value)  || 0;
  const operator = document.getElementById('prod-operator').value.trim();
  const shift    = document.getElementById('prod-shift').value;

  if (!machine || !partName || good <= 0) {
    showAlert('prod-alert','warn','⚠ Missing Info','Please select machine, part and enter qty produced.'); return;
  }

  const now = new Date();
  const time = now.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'});

  // Add to FG Stock
  const key = `${partName}|${variant}`;
  fgStock[key] = (fgStock[key] || 0) + good;

  // Log
  const entry = { time, machine, partName, variant, good, bad, operator: operator||'—', shift };
  prodLog.unshift(entry);
  stats.prod++;
  stats.fg = Object.keys(fgStock).filter(k => fgStock[k] > 0).length;
  stats.rej += bad;

  addActivity('prod', `${partName} (${variant}) — ${good} pcs from ${machine}`, bad > 0 ? `${bad} rejected` : 'No rejections', bad > 0 ? 'bad':'ok');
  updateDashStats();
  updateNavBadges();
  renderProdLog();
  showAlert('prod-alert','ok','✔ Recorded!',`${good} parts of ${partName} (${variant}) sent to FG Stock. ${bad > 0 ? bad+' pcs rejected.' : ''}`);
  clearProdForm();
}

function renderProdLog() {
  const tbody = document.getElementById('prod-log-body');
  if (!prodLog.length) { tbody.innerHTML = '<tr><td colspan="9"><div class="empty-state"><div class="empty-icon">⚙️</div>No production recorded yet</div></td></tr>'; return; }
  tbody.innerHTML = prodLog.map(e => `
    <tr>
      <td>${e.time}</td>
      <td><span class="mono">${e.machine}</span></td>
      <td><strong>${e.partName}</strong></td>
      <td><span class="tag ${e.variant==='RH'?'rh':e.variant==='LH'?'lh':'gen'}">${e.variant}</span></td>
      <td><strong style="color:var(--green)">${e.good}</strong></td>
      <td>${e.bad > 0 ? `<strong style="color:var(--red)">${e.bad}</strong>` : '—'}</td>
      <td>${e.operator}</td>
      <td>${e.shift.split(' ')[0]}</td>
      <td><span class="tag ok">Sent to FG</span></td>
    </tr>`).join('');

  // update prod stats
  const totalGood = prodLog.reduce((a,e)=>a+e.good,0);
  const totalBad  = prodLog.reduce((a,e)=>a+e.bad,0);
  const machines  = [...new Set(prodLog.map(e=>e.machine))].length;
  document.getElementById('prod-total').textContent = prodLog.length;
  document.getElementById('prod-qty').textContent   = totalGood;
  document.getElementById('prod-rej').textContent   = totalBad;
  document.getElementById('prod-machines').textContent = machines;
}

function clearProdForm() {
  ['prod-machine','prod-part','prod-variant'].forEach(id => document.getElementById(id).value = '');
  ['prod-qty-good','prod-operator'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('prod-qty-bad').value = '0';
}

