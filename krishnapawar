<script>
// ═══════════════════════════════
// DATA STORE
// ═══════════════════════════════
let parts = [
  { name:'Scalp Ridge', no:'UPC-SR-01', stdQty:28, tol:0, hsn:'3926', gst:18, variants:true, lowAlert:50 },
  { name:'Bumper Bracket', no:'UPC-205', stdQty:50, tol:2, hsn:'3926', gst:18, variants:true, lowAlert:100 },
  { name:'Clip Assembly', no:'UPC-309', stdQty:100, tol:5, hsn:'3926', gst:12, variants:false, lowAlert:200 },
  { name:'Dashboard Panel', no:'UPC-412', stdQty:20, tol:0, hsn:'3926', gst:18, variants:true, lowAlert:40 },
  { name:'Cover Plate', no:'UPC-101', stdQty:48, tol:2, hsn:'3926', gst:18, variants:false, lowAlert:96 },
  { name:'Knob Small', no:'UPC-502', stdQty:200, tol:10, hsn:'8708', gst:28, variants:false, lowAlert:300 },
];

// FG Stock: key = "partName|variant"
let fgStock = {};
let prodLog = [], dispLog = [], actLog = [];
let stats = { prod:0, fg:0, disp:0, rej:0, dispOk:0, dispRej:0, dispHold:0, invoiced:0 };
let currentDispResult = null;
let docCounter = { inv:1001, dc:2001 };

// Init FG bins
function initFGStock() {
  parts.forEach(p => {
    if (p.variants) {
      ['RH','LH'].forEach(v => {
        const k = `${p.name}|${v}`;
        if (!(k in fgStock)) fgStock[k] = 0;
      });
    } else {
      const k = `${p.name}|General`;
      if (!(k in fgStock)) fgStock[k] = 0;
    }
  });
}

// ═══════════════════════════════
// CLOCK
// ═══════════════════════════════
function tick() {
  const n = new Date();
  document.getElementById('clockTime').textContent = n.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'});
  document.getElementById('clockDate').textContent = n.toLocaleDateString('en-IN',{day:'2-digit',month:'short'});
}
tick(); setInterval(tick, 1000);

// ═══════════════════════════════
// NAVIGATION
// ═══════════════════════════════
function goPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  event.currentTarget.classList.add('active');
  if (id==='fgstock') renderFGStock();
  if (id==='parts') renderPartsTable();
  if (id==='production' || id==='dispatch' || id==='predispatch') populatePartSelects();
  if (id==='predispatch') { renderPDILog(); updatePDIStats(); if (!pdItems.length) addPDItem(); }
  if (id==='ai') { renderAIRecords(); }
}

