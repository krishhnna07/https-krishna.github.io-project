          ${validItems.map(item=>{
            const avail = fgStock[`${item.partName}|${item.variant}`]||0;
            const ok = avail >= item.qty;
            return `<tr>
              <td style="padding:5px 8px">${item.partName}</td>
              <td style="padding:5px 8px"><span class="tag ${item.variant==='RH'?'rh':item.variant==='LH'?'lh':'gen'}">${item.variant}</span></td>
              <td style="padding:5px 8px">${item.qty}</td>
              <td style="padding:5px 8px"><strong>${avail}</strong></td>
              <td style="padding:5px 8px"><span class="tag ${ok?'ok':'bad'}">${ok?'✔ Sufficient':'✖ Short by '+(item.qty-avail)}</span></td>
            </tr>`;
          }).join('')}
        </tbody>
      </table>
    </div>

    <div style="margin-top:14px;padding:10px 14px;background:#fef9c3;border-radius:7px;font-size:11px;color:#92400e;border:1px solid #fbbf24">
      ⚠ <strong>This is a Pre-Dispatch Invoice only.</strong> This document is for internal planning and customer communication purposes. 
      It does not constitute a Tax Invoice. A formal GST Tax Invoice will be issued at the time of actual dispatch.
    </div>

