function exportCSV(type) {
  let rows, headers, filename;
  if (type==='prod') {
    headers = ['Time','Machine','Part','Variant','Good Qty','Rejected','Operator','Shift'];
    rows = prodLog.map(e=>[e.time,e.machine,e.partName,e.variant,e.good,e.bad,e.operator,e.shift]);
    filename = 'Production_Log';
  } else {
    headers = ['Time','Part','Variant','Bin','Expected','Actual','Diff','Action','Engineer'];
    rows = dispLog.map(e=>[e.time,e.partName,e.variant,e.bin,e.expected,e.actual,e.diff,e.action,e.engineer]);
    filename = 'Dispatch_Log';
  }
  if (type==='pd') {
    headers = ['PDI No.','Date','Customer','PO No.','Parts','Total Qty','Grand Total','Status'];
    rows = pdiLog.map(e=>[
      e.pdiNo, e.date, e.customer, e.po,
      e.items.map(i=>i.partName+'('+i.variant+')').join('; '),
      e.totalQty, e.grandTotal.toFixed(2), e.status
    ]);
    filename = 'PreDispatch_Invoice_Register';
  }
  if (!rows.length) { alert('No data to export yet.'); return; }
  const csv = [headers,...rows].map(r=>r.join(',')).join('\n');
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
  a.download = `${filename}_${new Date().toLocaleDateString('en-IN').replace(/\//g,'-')}.csv`;
  a.click();
}

