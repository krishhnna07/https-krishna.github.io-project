let fgViewMode = 'grid';

function toggleFGView() {
  fgViewMode = fgViewMode === 'grid' ? 'table' : 'grid';
  document.getElementById('fg-bins-grid').style.display   = fgViewMode==='grid'  ? 'grid' : 'none';
  document.getElementById('fg-table-view').style.display  = fgViewMode==='table' ? 'block': 'none';
  document.getElementById('fgViewBtn').textContent = fgViewMode==='grid' ? 'Switch to Table' : 'Switch to Grid';
  renderFGStock();
}

function renderFGStock() {
  const grid  = document.getElementById('fg-bins-grid');
  const tbody = document.getElementById('fg-table-body');
  const keys  = Object.keys(fgStock);

  let totalBins = 0, totalQty = 0, lowCount = 0, emptyCount = 0;

  const gridHTML = keys.map(k => {
    const [pName, variant] = k.split('|');
    const p = parts.find(x => x.name === pName);
    if (!p) return '';
    const qty = fgStock[k];
    const isEmpty = qty === 0;
    const isLow   = qty > 0 && qty < p.lowAlert;
    if (!isEmpty) totalBins++;
    totalQty += qty;
    if (isEmpty) emptyCount++;
    else if (isLow) lowCount++;

    const qtyClass = isEmpty ? 'empty' : isLow ? 'low' : 'full';
    const icon = variant==='RH' ? '📦' : variant==='LH' ? '📫' : '🗃️';
    return `<div class="bin-card ${isEmpty?'empty-bin':''}">
      <div class="bin-icon">${icon}</div>
      <div class="bin-name">${pName}</div>
      <div class="bin-partno"><span class="tag ${variant==='RH'?'rh':variant==='LH'?'lh':'gen'}">${variant}</span> · ${p.no}</div>
      <div class="bin-qty ${qtyClass}">${qty}</div>
      <div class="bin-std">Std: ${p.stdQty} / bin</div>
    </div>`;
  }).join('');

  grid.innerHTML = gridHTML || '<div class="empty-state"><div class="empty-icon">📦</div>No bins yet. Record production first.</div>';

  tbody.innerHTML = keys.map(k => {
    const [pName, variant] = k.split('|');
    const p = parts.find(x => x.name === pName);
    if (!p) return '';
    const qty = fgStock[k];
    const isEmpty = qty === 0;
    const isLow   = qty > 0 && qty < p.lowAlert;
    const statusTag = isEmpty ? '<span class="tag bad">Empty</span>' : isLow ? '<span class="tag hold">Low</span>' : '<span class="tag ok">OK</span>';
    return `<tr>
      <td><strong>${pName}</strong></td>
      <td><span class="mono">${p.no}</span></td>
      <td><span class="tag ${variant==='RH'?'rh':variant==='LH'?'lh':'gen'}">${variant}</span></td>
      <td>BIN-${pName.substring(0,3).toUpperCase()}-${variant}</td>
      <td><span class="qty-badge ${isEmpty?'low':isLow?'low':'ok'}">${qty}</span></td>
      <td>${p.stdQty}</td>
      <td>${statusTag}</td>
      <td><button class="btn btn-ghost" style="padding:4px 12px;font-size:12px" onclick="quickDeduct('${k}')">− Deduct</button></td>
    </tr>`;
  }).join('') || '<tr><td colspan="8"><div class="empty-state">No FG stock yet</div></td></tr>';

  // Update FG stats
  document.getElementById('fg-total-bins').textContent = totalBins;
  document.getElementById('fg-total-qty').textContent  = totalQty;
  document.getElementById('fg-low').textContent        = lowCount;
  document.getElementById('fg-empty').textContent      = emptyCount;
  document.getElementById('nb-fg').textContent         = totalBins;
  stats.fg = totalBins;
  updateDashStats();
}

function adjustFGStock() {
  const partName = document.getElementById('fg-adj-part').value;
  const variant  = document.getElementById('fg-adj-variant').value;
  const qty      = parseInt(document.getElementById('fg-adj-qty').value);
  const reason   = document.getElementById('fg-adj-reason').value;
  if (!partName || isNaN(qty)) { alert('Select part and enter quantity.'); return; }
  const k = `${partName}|${variant}`;
  fgStock[k] = Math.max(0, (fgStock[k]||0) + qty);
  addActivity('fg', `Manual adjustment: ${partName} (${variant}) ${qty>0?'+':''}${qty}`, reason, qty>=0?'info':'bad');
  renderFGStock();
}

function quickDeduct(key) {
  const amt = parseInt(prompt('How many to deduct?','0'));
  if (isNaN(amt) || amt <= 0) return;
  fgStock[key] = Math.max(0, (fgStock[key]||0) - amt);
  renderFGStock();
}

// ═══════════════════════════════
// DISPATCH — BIN VERIFY
// ═══════════════════════════════
function verifyDispBin() {
  const partName = document.getElementById('disp-part').value;
  const variant  = document.getElementById('disp-variant').value;
  const actual   = parseInt(document.getElementById('disp-count').value);
  if (!partName) { showAlert('disp-alert','warn','⚠ Select Part','Please select a part first.'); return; }
  if (isNaN(actual)) { showAlert('disp-alert','warn','⚠ Enter Count','Please enter the actual count.'); return; }

  const p = parts.find(x => x.name === partName);
  const key = `${partName}|${variant}`;
  const fgQty = fgStock[key] || 0;
  const diff  = actual - p.stdQty;
  const absDiff = Math.abs(diff);
  const within  = absDiff <= p.tol;

  currentDispResult = { partName, variant, partNo: p.no, expected: p.stdQty, actual, diff, fgQty, tol: p.tol };

  const alertEl = document.getElementById('disp-alert');
  const actionEl = document.getElementById('disp-action-btns');

  let cls, title, msg;

  if (fgQty === 0) {
    cls='warn'; title='⚠ No Stock in FG'; msg=`FG Stock shows 0 for ${partName} (${variant}). Verify with FG Store before proceeding.`;
  } else if (actual === 0) {
    cls='bad'; title='✖ Empty Bin — Reject!'; msg='Bin count is zero. Do not dispatch.';
  } else if (within) {
    cls='ok';
    title = diff===0 ? '✔ Perfect Match!' : '✔ Within Tolerance — Acceptable';
    msg = `Expected: <strong>${p.stdQty}</strong> | Actual: <strong>${actual}</strong> | Diff: <strong>${diff===0?'Exact':diff>0?'+'+diff:diff}</strong> | FG Stock: <strong>${fgQty} pcs available</strong>`;
  } else {
    cls='bad';
    title = diff<0 ? `✖ SHORT by ${absDiff} parts` : `✖ EXCESS by ${absDiff} parts`;
    msg = diff<0
      ? `Bin has ${absDiff} fewer parts than standard of ${p.stdQty}. Recount or reject.`
      : `Bin has ${absDiff} extra parts. Verify packing before dispatch.`;
  }

  alertEl.className = `alert ${cls}`;
  alertEl.innerHTML = `<div class="alert-title">${title}</div><div style="font-size:13px">${msg}</div>
    <div class="alert-grid">
      <div class="alert-item"><div class="alert-item-lbl">Part</div><div class="alert-item-val">${partName}</div></div>
      <div class="alert-item"><div class="alert-item-lbl">Variant</div><div class="alert-item-val"><span class="tag ${variant==='RH'?'rh':variant==='LH'?'lh':'gen'}">${variant}</span></div></div>
      <div class="alert-item"><div class="alert-item-lbl">Expected</div><div class="alert-item-val">${p.stdQty}</div></div>
      <div class="alert-item"><div class="alert-item-lbl">Actual Count</div><div class="alert-item-val">${actual}</div></div>
      <div class="alert-item"><div class="alert-item-lbl">Difference</div><div class="alert-item-val">${diff===0?'0 ✓':diff>0?'+'+diff:diff}</div></div>
      <div class="alert-item"><div class="alert-item-lbl">FG Stock Avail.</div><div class="alert-item-val">${fgQty} pcs</div></div>
    </div>`;
  alertEl.style.display = 'block';
  actionEl.style.display = 'flex';
}

function dispAction(action) {
  if (!currentDispResult) return;
  const r = currentDispResult;
  const time = new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  const engineer = document.getElementById('disp-engineer').value.trim() || 'Engineer';
  const bin      = document.getElementById('disp-bin').value.trim() || '—';

  const entry = { time, partName: r.partName, variant: r.variant, partNo: r.partNo,
    expected: r.expected, actual: r.actual, diff: r.diff, bin, engineer, action };
  dispLog.unshift(entry);

  if (action==='ACCEPT') {
    stats.dispOk++;
    // Deduct from FG
    const k = `${r.partName}|${r.variant}`;
    fgStock[k] = Math.max(0, (fgStock[k]||0) - r.actual);
    addActivity('dispatch', `ACCEPTED: ${r.partName} (${r.variant}) — ${r.actual} pcs`, `Bin: ${bin} | By: ${engineer}`, 'ok');
  } else if (action==='REJECT') {
    stats.dispRej++; stats.rej++;
    addActivity('dispatch', `REJECTED: ${r.partName} (${r.variant}) — Bin: ${bin}`, `Diff: ${r.diff} | By: ${engineer}`, 'bad');
  } else {
    stats.dispHold++;
    addActivity('dispatch', `ON HOLD: ${r.partName} (${r.variant}) — Bin: ${bin}`, `Pending recheck | By: ${engineer}`, 'hold');
  }

  stats.disp = stats.dispOk;
  updateDashStats();
  updateNavBadges();
  renderDispLog();
  renderFGStock();

  // Reset
  document.getElementById('disp-alert').style.display = 'none';
  document.getElementById('disp-action-btns').style.display = 'none';
  document.getElementById('disp-count').value = '';
  document.getElementById('disp-bin').value = '';
  currentDispResult = null;
}

function renderDispLog() {
  const tbody = document.getElementById('disp-log-body');
  if (!dispLog.length) { tbody.innerHTML='<tr><td colspan="8"><div class="empty-state"><div class="empty-icon">🚚</div>No dispatch entries yet</div></td></tr>'; return; }
  tbody.innerHTML = dispLog.map(e => `
    <tr>
      <td>${e.time}</td>
      <td><strong>${e.partName}</strong></td>
      <td><span class="tag ${e.variant==='RH'?'rh':e.variant==='LH'?'lh':'gen'}">${e.variant}</span></td>
      <td>${e.bin}</td>
      <td>${e.expected}</td>
      <td>${e.actual}</td>
      <td><span class="tag ${e.action==='ACCEPT'?'ok':e.action==='REJECT'?'bad':'hold'}">${e.action}</span></td>
      <td>${e.engineer}</td>
    </tr>`).join('');
  document.getElementById('disp-ok').textContent      = stats.dispOk;
  document.getElementById('disp-rej').textContent     = stats.dispRej;
  document.getElementById('disp-hold').textContent    = stats.dispHold;
  document.getElementById('disp-invoiced').textContent= stats.invoiced;
  document.getElementById('nb-disp').textContent = dispLog.length;
}

