          <button class="ai-quick" onclick="aiQuick('What are the common reasons for bin rejection at dispatch?')">🔍 Bin Rejection Reasons</button>
          <button class="ai-quick" onclick="aiQuick('How should I handle a customer complaint about wrong quantity?')">⚠ Customer Complaint SOP</button>
          <button class="ai-quick" onclick="aiQuick('Explain what IATF 16949 requires from the dispatch department')">📋 IATF Dispatch Requirements</button>
          <button class="ai-quick" onclick="aiQuick('What documents are needed for dispatch to Uno Mindarika?')">📄 Uno Mindarika Docs</button>
          <button class="ai-quick" onclick="aiQuick('How to calculate CGST and SGST for an invoice of ₹9702 at 18% GST?')">🧮 GST Calculation Help</button>
        </div>

        <div class="ai-input-area">
          <div class="ai-input-row">
            <input type="text" id="aiInput"
              placeholder="Ask anything about dispatch, production, invoices, SOPs..."
              onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendAIMessage()}" />
            <button id="aiSendBtn" onclick="sendAIMessage()">Send ▶</button>
          </div>
          <div style="font-size:11px;color:var(--muted);margin-top:7px;text-align:center">
            💡 Tip: Mention part names, customer names, or invoice numbers for more precise answers
          </div>
        </div>
      </div>
    </div>

    <!-- RIGHT: RECORDS + STATS -->
    <div class="ai-records-panel">

      <!-- STATS -->
      <div class="card">
        <div class="card-head" style="background:#7c3aed"><span>📈 AI Usage This Session</span></div>
        <div class="card-body">
          <div class="ai-stat-row">
            <div class="ai-stat"><div class="ai-stat-val" id="ai-stat-total">0</div><div class="ai-stat-lbl">Total Queries</div></div>
            <div class="ai-stat"><div class="ai-stat-val" id="ai-stat-records">0</div><div class="ai-stat-lbl">Records Saved</div></div>
          </div>
        </div>
      </div>

      <!-- SAVED RECORDS -->
      <div class="ai-rec-card">
        <div class="ai-rec-head">
          <span>🗂 Saved AI Records</span>
          <button class="export-btn" onclick="exportAIRecords()">⬇ Export</button>
        </div>
        <div class="ai-rec-body" id="aiRecordsBody">
          <div class="empty-state"><div class="empty-icon" style="font-size:32px">🗂</div>No records yet. Start chatting and records will appear here.</div>
        </div>
      </div>

      <!-- SAVE NOTE -->
      <div class="card">
        <div class="card-head" style="background:#7c3aed"><span>📝 Save a Manual Note</span></div>
        <div class="card-body">
          <div class="f-group" style="margin-bottom:10px">
            <label>Category</label>
            <select id="aiNoteCategory">
              <option value="issue">🔴 Issue / Problem</option>
              <option value="task">🟢 Task / Action Item</option>
              <option value="report">🔵 Report / Observation</option>
              <option value="query">🟣 Query / Pending Answer</option>
            </select>
          </div>
          <div class="f-group" style="margin-bottom:10px">
            <label>Title</label>
            <input type="text" id="aiNoteTitle" placeholder="e.g. Scalp Ridge RH short by 5 pcs" />
          </div>
          <div class="f-group" style="margin-bottom:12px">
            <label>Details</label>
            <textarea id="aiNoteBody" rows="3"
              style="width:100%;padding:9px 12px;border:1.5px solid var(--border);border-radius:8px;font-size:13px;font-family:inherit;resize:vertical;outline:none"
              placeholder="Write any observation, issue, or action item here..."></textarea>
          </div>
          <button class="btn btn-blue" style="background:#7c3aed;width:100%" onclick="saveManualNote()">💾 Save Record</button>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- AI JAVASCRIPT -->
<script>
// ═══════════════════════════════
// AI ASSISTANT
// ═══════════════════════════════
let aiRecords = [];
let aiQueryCount = 0;

function getPlantContext() {
  // Build a live snapshot of plant data to give to AI
  const prodSummary = prodLog.length
    ? prodLog.slice(0,5).map(e=>`${e.partName}(${e.variant}): ${e.good} good, ${e.bad} rejected from ${e.machine}`).join('; ')
    : 'No production recorded today';

  const fgSummary = Object.entries(fgStock)
    .map(([k,v]) => {
      const [pName, variant] = k.split('|');
      const p = parts.find(x=>x.name===pName);
      return `${pName}(${variant}): ${v} pcs${p&&v<p.lowAlert?' [LOW]':''}`;
    }).join(', ') || 'No FG stock data';

  const dispSummary = dispLog.length
    ? `${stats.dispOk} accepted, ${stats.dispRej} rejected, ${stats.dispHold} on hold today`
    : 'No dispatch activity today';

  const partsList = parts.map(p=>`${p.name}(${p.no}, std qty/bin:${p.stdQty}${p.variants?', RH+LH':''}, HSN:${p.hsn}, GST:${p.gst}%)`).join('; ');

  return `You are an expert AI assistant for Unitech Plasto Components Pvt Ltd, a plastic injection moulding company in Kharabwadi, Chakan, Pune - 410501. GSTIN: 27AAACU6211E1ZP. The company supplies auto components to customers like Uno Mindarika Pvt Ltd, Bajaj Auto, TVS Motors, Tata Motors, Mahindra.

LIVE PLANT DATA (as of right now):
- Production today: ${prodSummary}
- FG Stock: ${fgSummary}
- Dispatch today: ${dispSummary}
- Invoices generated: ${stats.invoiced}
- Total rejections: ${stats.rej}

PART MASTER: ${partsList}

PLANT WORKFLOW: Production Hall (20 moulding machines) → FG Stock (bins, RH/LH variants) → Pre-Dispatch Invoice → Dispatch (bin verification + Tax Invoice/DC)

You are helpful, practical, and speak in simple English (not too formal). The user is a Junior Dispatch Engineer named Krishna at this plant. Give specific, actionable answers. For SOPs, give step-by-step guidance. For calculations, show the working. For emails/letters, draft them fully. Keep responses clear and well-structured. When referencing plant data above, use it naturally in your answer.`;
}

async function sendAIMessage() {
  const input = document.getElementById('aiInput');
  const btn   = document.getElementById('aiSendBtn');
  const text  = input.value.trim();
  if (!text) return;

  input.value = '';
  btn.disabled = true;
  aiQueryCount++;
  document.getElementById('ai-stat-total').textContent = aiQueryCount;

  addAIMsg('user', text);
  const loadingEl = addAILoading();

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-6',
        max_tokens: 1000,
        system: getPlantContext(),
        messages: [{ role: 'user', content: text }]
      })
    });

    const data = await res.json();
    const reply = data.content?.[0]?.text || 'Sorry, I could not get a response. Please try again.';

    loadingEl.remove();
    addAIMsg('ai', reply);

    // Auto-save as record
    saveAIRecord(text, reply, autoDetectCategory(text));

  } catch (err) {
    loadingEl.remove();
    addAIMsg('ai', '⚠ Connection error. Please check your internet and try again.');
    console.error(err);
  }

  btn.disabled = false;
  input.focus();
}

function aiQuick(text) {
  document.getElementById('aiInput').value = text;
  sendAIMessage();
}

function addAIMsg(role, text) {
  const box = document.getElementById('aiMessages');
  const div = document.createElement('div');
  div.className = `ai-msg ${role==='ai' ? 'ai-side' : 'user'}`;

  // Convert markdown-like to HTML
  const html = text
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.*?)\*/g, '<em>$1</em>')
    .replace(/^### (.*$)/gm, '<strong style="font-size:14px;display:block;margin-top:8px;margin-bottom:4px">$1</strong>')
    .replace(/^## (.*$)/gm,  '<strong style="font-size:15px;display:block;margin-top:10px;margin-bottom:4px">$1</strong>')
    .replace(/^- (.*$)/gm,   '<li style="margin-bottom:2px">$1</li>')
    .replace(/(<li.*<\/li>\n?)+/g, s => `<ul style="padding-left:16px;margin:6px 0">${s}</ul>`)
    .replace(/\n\n/g, '<br><br>')
    .replace(/\n/g, '<br>');

  div.innerHTML = `
    <div class="ai-msg-av">${role==='ai' ? '🤖' : 'KR'}</div>
    <div class="ai-bubble">${html}</div>`;
  box.appendChild(div);
  box.scrollTop = box.scrollHeight;
}

function addAILoading() {
  const box = document.getElementById('aiMessages');
  const div = document.createElement('div');
  div.className = 'ai-msg ai-side';
  div.innerHTML = `<div class="ai-msg-av">🤖</div>
    <div class="ai-bubble"><div class="ai-typing"><span></span><span></span><span></span></div></div>`;
  box.appendChild(div);
  box.scrollTop = box.scrollHeight;
  return div;
}

function autoDetectCategory(text) {
  const t = text.toLowerCase();
  if (t.includes('problem') || t.includes('reject') || t.includes('short') || t.includes('missing') || t.includes('wrong') || t.includes('issue')) return 'issue';
  if (t.includes('report') || t.includes('summary') || t.includes('status') || t.includes('today')) return 'report';
  if (t.includes('how') || t.includes('what') || t.includes('why') || t.includes('explain') || t.includes('?')) return 'query';
  return 'task';
}

function saveAIRecord(question, answer, category) {
  const now = new Date();
  const record = {
    id: Date.now(),
    category,
    title: question.length > 60 ? question.substring(0, 57) + '...' : question,
    question,
    answer,
    time: now.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' }),
    date: now.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' })
  };
  aiRecords.unshift(record);
  document.getElementById('ai-stat-records').textContent = aiRecords.length;
  document.getElementById('nb-ai').textContent = aiRecords.length;
  renderAIRecords();
}

function saveManualNote() {
  const category = document.getElementById('aiNoteCategory').value;
  const title    = document.getElementById('aiNoteTitle').value.trim();
  const body     = document.getElementById('aiNoteBody').value.trim();
  if (!title || !body) { alert('Please enter both title and details.'); return; }

  const now = new Date();
  aiRecords.unshift({
    id: Date.now(), category, title,
    question: `[Manual Note] ${title}`, answer: body,
    time: now.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}),
    date: now.toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'})
  });

  document.getElementById('aiNoteTitle').value = '';
  document.getElementById('aiNoteBody').value  = '';
  document.getElementById('ai-stat-records').textContent = aiRecords.length;
  document.getElementById('nb-ai').textContent = aiRecords.length;
  renderAIRecords();
  addActivity('ai', `Note saved: ${title}`, category, 'info');
  alert('✅ Record saved!');
}

function renderAIRecords() {
  const body = document.getElementById('aiRecordsBody');
  if (!aiRecords.length) {
    body.innerHTML = '<div class="empty-state"><div class="empty-icon" style="font-size:32px">🗂</div>No records yet.</div>';
    return;
  }
  const tagMap = {
    issue:  ['tag-issue',  '🔴 Issue'],
    task:   ['tag-task',   '🟢 Task'],
    report: ['tag-report', '🔵 Report'],
    query:  ['tag-query',  '🟣 Query'],
  };
  body.innerHTML = aiRecords.map((r,i) => {
    const [tagClass, tagLabel] = tagMap[r.category] || ['tag-query','🟣 Query'];
    return `<div class="ai-rec-item" onclick="viewAIRecord(${i})">
      <div class="ai-rec-item-title">${r.title}</div>
      <div class="ai-rec-item-meta">
        <span class="ai-rec-item-tag ${tagClass}">${tagLabel}</span>
        <span>${r.date} · ${r.time}</span>
      </div>
    </div>`;
  }).join('');
}

function viewAIRecord(i) {
  const r = aiRecords[i];
  // Scroll to AI chat and replay the conversation visually
  goPageDirect('ai');
  const box = document.getElementById('aiMessages');

  // Create a highlighted replay bubble
  const div = document.createElement('div');
  div.style.cssText = 'background:#f3f0ff;border:2px solid #7c3aed;border-radius:12px;padding:14px;margin:8px 0;font-size:13px';
  div.innerHTML = `<div style="font-size:11px;font-weight:700;color:#7c3aed;margin-bottom:8px">📂 RECORD from ${r.date} · ${r.time}</div>
    <div style="font-weight:700;margin-bottom:6px;color:var(--steel)">Q: ${r.question}</div>
    <div style="color:var(--ink);line-height:1.6">${r.answer.substring(0,300)}${r.answer.length>300?'...':''}</div>`;
  box.appendChild(div);
  box.scrollTop = box.scrollHeight;
}

function goPageDirect(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  const navBtns = document.querySelectorAll('.nav-btn');
  navBtns.forEach(b => { if (b.getAttribute('onclick')?.includes("'"+id+"'")) b.classList.add('active'); });
}

function exportAIRecords() {
  if (!aiRecords.length) { alert('No records to export.'); return; }
  const headers = ['Date','Time','Category','Title','Question','Answer'];
  const rows = aiRecords.map(r => [
    r.date, r.time, r.category,
    `"${r.title.replace(/"/g,'""')}"`,
    `"${r.question.replace(/"/g,'""')}"`,
    `"${r.answer.substring(0,500).replace(/"/g,'""')}"`
  ]);
  const csv = [headers,...rows].map(r=>r.join(',')).join('\n');
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
  a.download = `AI_Records_${new Date().toLocaleDateString('en-IN').replace(/\//g,'-')}.csv`;
  a.click();
}
</script>
</body>
</html>
