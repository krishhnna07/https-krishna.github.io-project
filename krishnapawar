  document.getElementById('pd-preview-wrap').scrollIntoView({ behavior:'smooth', block:'nearest' });
}

function clearPDForm() {
  pdItems = [];
  renderPDItems();
  ['pd-customer','pd-po','pd-date','pd-gstin','pd-address','pd-remarks','pd-preparedby'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.value = '';
  });
  document.getElementById('pd-preview-wrap').innerHTML = '';
  document.getElementById('pd-print-btn').style.display = 'none';
  document.getElementById('pd-alert').style.display = 'none';
}

function updatePDIStats() {
  document.getElementById('pd-total').textContent     = pdiStats.total;
  document.getElementById('pd-pending').textContent   = pdiStats.pending;
  document.getElementById('pd-approved').textContent  = pdiStats.approved;
  document.getElementById('pd-converted').textContent = pdiStats.converted;
}

function approvePDI(idx) {
  const pdi = pdiLog[idx];
  if (pdi.status === 'Pending') {
    pdi.status = 'Approved';
    pdiStats.pending  = Math.max(0, pdiStats.pending-1);
    pdiStats.approved++;
    updatePDIStats();
    renderPDILog();
    addActivity('pre-disp', `PDI Approved: ${pdi.pdiNo} — ${pdi.customer}`, `Ready for dispatch`, 'ok');
  }
}

function convertToInvoice(idx) {
  const pdi = pdiLog[idx];
  if (pdi.status !== 'Converted') {
    pdi.status = 'Converted';
    if (pdi.status === 'Approved') pdiStats.approved = Math.max(0, pdiStats.approved-1);
    else pdiStats.pending = Math.max(0, pdiStats.pending-1);
    pdiStats.converted++;
    stats.invoiced++;
    updatePDIStats();
    renderPDILog();
    addActivity('dispatch', `PDI ${pdi.pdiNo} converted to Tax Invoice`, `Customer: ${pdi.customer}`, 'ok');
    alert(`PDI ${pdi.pdiNo} marked as Converted to Tax Invoice. Go to Dispatch tab to generate the final invoice.`);
  }
}

function renderPDILog() {
  const tbody = document.getElementById('pd-log-body');
  if (!pdiLog.length) {
    tbody.innerHTML = '<tr><td colspan="9"><div class="empty-state"><div class="empty-icon">📋</div>No pre-dispatch invoices yet</div></td></tr>';
    return;
  }
  tbody.innerHTML = pdiLog.map((e, i) => {
    const statusColor = e.status==='Approved'?'ok':e.status==='Converted'?'fg':'hold';
    const partsSummary = e.items.map(x=>`${x.partName}(${x.variant})`).join(', ');
    return `<tr>
      <td><span class="mono">${e.pdiNo}</span></td>
      <td>${e.date}</td>
      <td><strong>${e.customer}</strong></td>
      <td>${e.po}</td>
      <td style="font-size:11px;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${partsSummary}">${partsSummary}</td>
      <td><strong>${e.totalQty}</strong></td>
      <td><strong style="color:var(--green)">₹${e.grandTotal.toFixed(2)}</strong></td>
      <td><span class="tag ${statusColor}">${e.status}</span></td>
      <td style="white-space:nowrap">
        ${e.status==='Pending'?`<button class="btn btn-green" style="padding:4px 10px;font-size:11px;margin-right:4px" onclick="approvePDI(${i})">✔ Approve</button>`:''}
        ${e.status!=='Converted'?`<button class="btn btn-blue" style="padding:4px 10px;font-size:11px" onclick="convertToInvoice(${i})">→ Invoice</button>`:'<span style="color:var(--muted);font-size:12px">Done</span>'}
      </td>
    </tr>`;
  }).join('');
  document.getElementById('nb-pd').textContent = pdiLog.length;
}


initFGStock();
populatePartSelects();
renderPartsTable();
updateDashStats();
updateNavBadges();
</script>

